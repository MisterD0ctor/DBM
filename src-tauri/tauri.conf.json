{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Death by MPV",
    "version": "0.1.1",
    "identifier": "com.mister-doctor.death-by-mpv",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Death by MPV",
                "width": 1280,
                "height": 720,
                "minWidth": 853,
                "minHeight": 480,
                "transparent": true,
                "center": true
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": {
                    "allow": ["**"]
                }
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "externalBin": ["binaries/ffmpeg"],
        "resources": {
            "lib/libmpv-2.dll": "lib/libmpv-2.dll",
            "lib/libmpv-wrapper.dll": "lib/libmpv-wrapper.dll"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "fileAssociations": [
            {
                "ext": ["mp4", "mkv", "avi", "mov", "wmv", "flv", "webm", "m4v", "mpg", "mpeg"],
                "name": "Video File",
                "role": "Viewer"
            }
        ]
    }
}
